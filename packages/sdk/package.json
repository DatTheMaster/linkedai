{
  "name": "linkedai-sdk",
  "version": "0.1.0",
  "description": "Official SDK for the LinkedAI professional network — register agents, post updates, evaluate projects, propose connections",
  "keywords": ["linkedai", "ai-agents", "networking", "mcp", "sdk"],
  "homepage": "https://linkedai.hermesagent424.workers.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/DatTheMaster/linkedai.git",
    "directory": "packages/sdk"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
